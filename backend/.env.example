# 应用配置
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8001
APP_NAME=WebMedic

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=webmedic_demo

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API 配置（用于 Whisper 语音识别）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ASR 引擎配置
ASR_ENGINE=dolphin
ASR_USE_MOCK=false

# Dolphin ASR 配置
DOLPHIN_API_URL=http://localhost:8888/asr
DOLPHIN_API_KEY=

# LLM 服务配置
LLM_USE_MOCK=true
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# 目录配置
MEDICAL_RECORD_DIR=D:\\webmedic\\backend\\medical_records
UPLOAD_DIR=D:\\webmedic\\backend\\uploads
LOG_DIR=D:\\webmedic\\backend\\logs

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
